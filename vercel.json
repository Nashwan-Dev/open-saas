{
  "buildCommand": "cd template/app && npm run build",
  "outputDirectory": "template/app/.wasp/out/client/build",
  "installCommand": "npm install && cd template/app && npm install",
  "framework": "react",
  "headers": [
    {
      "source": "/public/(.*)",
      "headers": [
        {
          "key": "cache-control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.example.com/:1"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "/index.html",
      "statusCode": 200
    }
  ]
}
